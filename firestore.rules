rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - fullName: string (required)
    //   - idNumber: string (required)
    //   - email: string (optional)
    //   - role: string (required, 'student' | 'admin')
    //   - yearLevel: string (required for students, '1st Year'|'2nd Year'|'3rd Year'|'4th Year')
    //   - lastLogin: timestamp (optional)
    //   - createdAt: timestamp (optional)
    //   - photoURL: string (optional)
    //
    // Collection: ratings
    // Collection: studyGroups
    // Collection: questions
    // Collection: resources
    // Collection: userProgress
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "rashmae26@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidYearLevel(level) {
      return level in ['1st Year', '2nd Year', '3rd Year', '4th Year'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'idNumber', 'role', 'yearLevel']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.idNumber is string && data.idNumber.size() > 0 && data.idNumber.size() < 20 &&
             data.role in ['student', 'admin'] &&
             isValidYearLevel(data.yearLevel);
    }

    function isValidUserUpdate(data) {
      return data.uid is string && data.uid.size() > 0;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['title', 'subjectId', 'userId', 'userName', 'type', 'url', 'isPublic', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 255 &&
             data.url is string && data.url.size() > 0 &&
             data.isPublic is bool &&
             data.createdAt is timestamp;
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['progressMap', 'updatedAt']) &&
             data.progressMap is map &&
             data.updatedAt is timestamp;
    }

    function isValidRating(data) {
      return data.keys().hasAll(['subjectId', 'userId', 'userName', 'rating', 'createdAt']) &&
             data.subjectId is string &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.createdAt is timestamp;
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['title', 'userId', 'userName', 'votes', 'answerCount', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 5 && data.title.size() < 255 &&
             data.votes is number &&
             data.answerCount is number &&
             data.createdAt is timestamp;
    }

    function isValidStudyGroup(data) {
      return data.keys().hasAll(['name', 'subjectCode', 'members', 'creatorId', 'createdAt']) &&
             data.creatorId == request.auth.uid &&
             data.name is string && data.name.size() > 3 && data.name.size() < 50 &&
             data.members is list &&
             data.createdAt is timestamp;
    }

    // Users: only owner or admin can read; creation requires valid data;
    // updates preserve role unless admin
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() &&
                       isOwner(userId) &&
                       isValidUser(request.resource.data) &&
                       (request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && (
                       (isOwner(userId) &&
                        request.resource.data.role == resource.data.role &&
                        isValidUserUpdate(request.resource.data)) ||
                       isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRating(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /studyGroups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStudyGroup(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.resource.data.members.hasAll(resource.data.members)) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQuestion(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']) &&
         math.abs(request.resource.data.votes - resource.data.votes) == 1) ||
        (request.resource.data.userId == request.auth.uid && isValidQuestion(request.resource.data)) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated() && (
        resource.data.isPublic == true ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidResource(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && isValidResource(request.resource.data)) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /userProgress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidUserProgress(request.resource.data);
    }
  }
}
